    "ofetch": "^1.5.1",
    "pathe": "^2.0.3",
    "puppeteer-cluster": "^0.25.0",
    "puppeteer-core": "^24.40.0",
    "radix3": "^1.1.2",
    "regexparam": "^3.0.0",
    "sanitize-filename": "^1.6.4",
    "sitemapper": "^4.1.4",
    "slugify": "^1.6.9",
    "tinyexec": "^1.1.1",
    "tinyglobby": "^0.2.16",
    "ufo": "^1.6.3",
    "ultrahtml": "^1.6.0",
    "unctx": "^2.5.0",
