    "lodash-es": "^4.18.1",
    "pathe": "^2.0.3",
    "std-env": "^4.0.0",
    "tinyexec": "^1.1.1",
    "tinyglobby": "^0.2.16",
    "@unlighthouse/client": "0.17.9",
    "@unlighthouse/core": "0.17.9",
    "@unlighthouse/server": "0.17.9"
